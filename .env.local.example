# Resend Email Service
RESEND_API_KEY=re_your_key
RESEND_FROM=No-Reply<no-reply@baamplatform.com>
CONTACT_FALLBACK_TO=support@baamplatform.com

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:5000

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
JWT_SECRET="your-jwt-secret"
SUPABASE_STORAGE_BUCKET=media

# Image APIs
PEXELS_API_KEY="your-pexels-key"
UNSPLASH_ACCESS_KEY="your-unsplash-access-key"
UNSPLASH_SECRET_KEY="your-unsplash-secret-key"

# AI
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY="sk-proj-your-key"
AI_REWRITE_CLAUDE_MODEL=claude-sonnet-4-6
AI_REWRITE_OPENAI_MODEL=gpt-5.4
ANTHROPIC_MAIN_MODEL=claude-sonnet-4-6
OPENAI_MAIN_MODEL=gpt-5.4
